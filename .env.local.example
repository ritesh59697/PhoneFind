# Copy this file to .env.local and fill in real values before running locally.

# Used to sign JWTs for both user login sessions and device API keys.
# Generate a strong random value, e.g.: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

# From Firebase Console -> Project settings -> Service accounts ->
# Generate new private key. Paste the ENTIRE JSON contents as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
